# Server
PORT=8080
TRUSTED_PROXY_IPS=

# Database
DATABASE_URL=postgres://user:password@localhost:5432/serenity?sslmode=disable

# Auth
JWT_SECRET=change-me
JWT_ISSUER=serenity
JWT_AUDIENCE=serenity
BCRYPT_COST=12

# Rate Limits
LOGIN_RATE_LIMIT=5
LOGIN_RATE_LIMIT_WINDOW=1m
REGISTER_RATE_LIMIT=3
REGISTER_RATE_LIMIT_WINDOW=1m
PASSWORD_UPDATE_RATE_LIMIT=3
PASSWORD_UPDATE_RATE_LIMIT_WINDOW=1m

# Permission Cache
PERMISSION_CACHE_TTL=45s
PERMISSION_CACHE_MAX_SIZE=1000
